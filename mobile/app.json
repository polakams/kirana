{
  "expo": {
    "name": "Kirana",
    "slug": "kirana",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSSpeechRecognitionUsageDescription": "Kirana uses speech recognition to understand your grocery orders.",
        "NSMicrophoneUsageDescription": "Kirana uses the microphone so you can speak your grocery list."
      }
    },
    "android": {
      "package": "com.kirana.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": ["RECORD_AUDIO", "INTERNET"]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-speech-recognition"
    ],
    "scheme": "kirana",
    "experiments": {
      "typedRoutes": true
    }
  }
}
