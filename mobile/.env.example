# ============================================================
# Kirana — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local — it is in .gitignore.
# ============================================================

# --- SERVER-SIDE ONLY (Expo API Routes) ---
# These are never sent to the client bundle.
# In production, set these as EAS Environment Secrets:
#   eas env:create --scope project --name CLAUDE_API_KEY --environment production

# Anthropic Claude API key (for AI order parsing)
CLAUDE_API_KEY=sk-ant-your-key-here

# WhatsApp GKE service endpoint
WHATSAPP_API_URL=https://api.dapexim.com/api/send-message

# WhatsApp GKE Bearer token
WHATSAPP_BEARER_TOKEN=your-bearer-token-here

# Sender WhatsApp number (no + prefix)
WHATSAPP_FROM_NUMBER=15856875843

# --- CLIENT-SAFE (bundled into the app) ---
# Development: your Mac's LAN IP + Expo dev server port
# Production:  EAS Deploy URL (set automatically via eas.json build env)
EXPO_PUBLIC_API_URL=http://10.0.0.227:8081
