# Claude API key - stored server-side in the Expo API Route
# The app reads this to call Claude for parsing grocery orders
CLAUDE_API_KEY=sk-ant-your-key-here

# API URL for the Expo API Route
# In development: http://localhost:8081
# In production: your deployed URL (e.g. https://your-app.expo.app)
EXPO_PUBLIC_API_URL=http://localhost:8081
